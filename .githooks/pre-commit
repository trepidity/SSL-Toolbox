#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks not found in PATH; install with 'brew install gitleaks'." >&2
  exit 1
fi

echo "Running pre-commit gitleaks scan..."
gitleaks protect --staged --redact --no-banner --config .gitleaks.toml
